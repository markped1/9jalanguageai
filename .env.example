# GROQ_API_KEY: Required for AI chat and language discovery (text generation).
# Get a free key at https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# TAVILY_API_KEY: Required for web search grounding in language discovery.
# Get a free key at https://app.tavily.com (1,000 free searches/month)
TAVILY_API_KEY="your_tavily_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
