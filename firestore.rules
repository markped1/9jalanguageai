rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: user must be authenticated (Google OR anonymous)
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: authenticated user owns this document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper: signed-in user is the Master Admin via Google
    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'mckpedersen@gmail.com';
    }

    // ── Personal Vocabulary ──────────────────────────────────────────────────
    match /users/{userId}/personalVocab/{vocabId} {
      allow read: if isOwner(userId);
      // Allow any write as long as the user owns the path — the app validates data
      allow write: if isOwner(userId);
    }

    // ── Languages Repository ─────────────────────────────────────────────────
    match /languages/{languageId} {
      allow read: if true; // Publicly readable
      allow write: if isSignedIn(); // Any signed-in user (admin, dev, Google) can add languages
    }

    // ── Developer Accounts ───────────────────────────────────────────────────
    match /lexiconDevelopers/{devId} {
      allow read: if true;             // Public read so login verification works
      allow write: if isMasterAdmin(); // Only Master Admin can create/remove developers
    }

    // ── Core Vocabulary Audio (Lexicon Dictionary) ───────────────────────────
    match /coreVocabAudio/{audioId} {
      allow read: if true;       // Publicly readable for all users
      allow write: if isSignedIn(); // Any signed-in user (anonymous developer or Google admin) can write
    }

    // ── Community Vocabulary ─────────────────────────────────────────────────
    match /communityVocab/{vocabId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── AI Training Studio ───────────────────────────────────────────────────
    match /aiTraining/{entryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
