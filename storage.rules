rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read stored audio files (vocab pronunciations)
    match /vocab-audio/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /training-audio/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
