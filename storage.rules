rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Vocab and training audio — open read, open write (admin-controlled content)
    match /vocab-audio/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    match /training-audio/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
